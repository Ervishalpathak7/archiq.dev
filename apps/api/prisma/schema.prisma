generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  avatar    String
  clerkId   String   @unique
}

model Design {
  id          String   @id @default(cuid())
  title       String
  description String
  techStack   String
  body        Json
  updatedAt   DateTime @updatedAt
  authorId    String
}
