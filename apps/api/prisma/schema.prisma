generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  avatar    String
  clerkId   String   @unique
  designs   Design[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Design {
  id          String   @id @default(cuid())
  title       String
  description String?
  techStack   String
  body        Json
  scale       String
  traffic     String
  userPrompt  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId    String
  @@index([authorId])
}
